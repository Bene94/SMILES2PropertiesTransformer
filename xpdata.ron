XpV0(
    project: "data_processing",
    containers: {
        "main": (
            command: ["python", "data_processing/data_processing_cosmo.py"],
            
            build: [
                From("nvcr.io/nvidia/pytorch:21.03-py3"),
                Repo(path: "requirements.txt", cd: true),
                Run("pip install -r requirements.txt"),
                Repo(keep: true, cd: true),
            ],

            gpu: 0,
            gpu_mem: "0GB",
            
            env_secrets: {
                "WANDB_API_KEY": "wandb-api-key",
            },
            volumes: 
                {"/home/bene/NNGamma/data": "/mnt/xprun/data", 
                "/home/bene/NNGamma/raw_data": "/mnt/xprun/raw_data",
                "/home/bene/NNGamma/vocab": "/mnt/xprun/vocab",
                "/home/bene/NNGamma/Models": "/mnt/xprun/out",
                "/home/bene/NNGamma/Plot": "/mnt/xprun/plot",
                "/home/bene/NNGamma/temp": "/mnt/xprun/temp",
                "/home/bene/NNGamma/wandb": "/mnt/xprun/wandb",
            },
        ),
    }
)
