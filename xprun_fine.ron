XpV0(
    project: "GNN_FTS",
    containers: {
        "main": (
            command: ["python", "fine_tune_mult.py"],
            
            build: [
                From("nvcr.io/nvidia/pytorch:21.03-py3"),
                Repo(path: "requirements.txt", cd: true),
                Run("pip install -r requirements.txt"),
                Repo(keep: true, cd: true),
            ],

            gpu: 1,
            gpu_mem: "11GB",
            
            env_secrets: {
                "WANDB_API_KEY": "wandb-api-key",
            },
            volumes: 
                {"/home/bene/NNGamma/data": "/mnt/xprun/data", 
                "/home/bene/NNGamma/Models": "/mnt/xprun/out",
                "/home/bene/NNGamma/Plot": "/mnt/xprun/plot",
                "/home/bene/NNGamma/out_fine_tuen": "/mnt/xprun/temp",
            },
        ),
    }
)
